{
  "name": "@openpeep/claude-code",
  "version": "0.1.0",
  "description": "Claude Code plugin for OpenPeep — create files, preview peeps, build custom viewers",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openpeep-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.0.0"
  }
}
