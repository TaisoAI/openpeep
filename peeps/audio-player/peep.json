{
  "id": "audio-player",
  "name": "Audio Player",
  "version": "1.0.5",
  "description": "Play audio files with waveform visualization",
  "author": "OpenPeep",
  "entry": "index.html",
  "builtin": true,
  "priority": 0,
  "capabilities": [
    "view"
  ],
  "matches": {
    "extensions": [
      ".mp3",
      ".wav",
      ".ogg",
      ".m4a",
      ".aac",
      ".flac",
      ".wma",
      ".aiff",
      ".aif",
      ".opus",
      ".webm"
    ]
  }
}