{
  "id": "text-editor",
  "name": "Text Editor",
  "version": "1.0.4",
  "description": "View and edit text files with syntax hints",
  "author": "OpenPeep",
  "entry": "index.html",
  "builtin": true,
  "priority": 0,
  "capabilities": [
    "view",
    "edit",
    "save"
  ],
  "matches": {
    "extensions": [
      ".txt",
      ".js",
      ".mjs",
      ".cjs",
      ".ts",
      ".tsx",
      ".jsx",
      ".css",
      ".scss",
      ".less",
      ".sh",
      ".bash",
      ".zsh",
      ".py",
      ".rb",
      ".go",
      ".rs",
      ".java",
      ".kt",
      ".swift",
      ".c",
      ".cpp",
      ".h",
      ".hpp",
      ".yaml",
      ".yml",
      ".toml",
      ".ini",
      ".cfg",
      ".env",
      ".log",
      ".xml",
      ".sql",
      ".graphql",
      ".gql",
      ".vue",
      ".svelte",
      ".php",
      ".lua",
      ".r",
      ".dart",
      ".zig",
      ".nix",
      ".tf",
      ".proto",
      ".csv",
      ".tsv",
      ".gitignore",
      ".dockerignore",
      ".editorconfig",
      ".prettierrc"
    ]
  }
}